---
/**
 * Token Reference — Visual reference for all Remarque design tokens.
 * Shows colors (dual-mode light/dark), contrast ratios, spacing, widths, radii, and motion.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

// NOTE: keep these values in sync with tokens.css (issue #48 tracks
// generating this page from a machine-readable token source).
const colorPairs = [
  { name: '--color-bg', light: 'oklch(0.975 0.005 80)', dark: 'oklch(0.16 0.01 80)', desc: 'Page background' },
  { name: '--color-bg-subtle', light: 'oklch(0.955 0.005 80)', dark: 'oklch(0.19 0.01 80)', desc: 'Alternating sections' },
  { name: '--color-fg', light: 'oklch(0.18 0.01 80)', dark: 'oklch(0.90 0.005 80)', desc: 'Primary text' },
  { name: '--color-fg-muted', light: 'oklch(0.43 0.015 80)', dark: 'oklch(0.70 0.01 80)', desc: 'Secondary text' },
  { name: '--color-muted', light: 'oklch(0.54 0.01 80)', dark: 'oklch(0.60 0.01 80)', desc: 'Tertiary text' },
  { name: '--color-border', light: 'oklch(0.88 0.005 80)', dark: 'oklch(0.25 0.005 80)', desc: 'Quiet borders (decorative only)' },
  { name: '--color-border-bold', light: 'oklch(0.62 0.01 80)', dark: 'oklch(0.50 0.01 80)', desc: 'Functional borders' },
  { name: '--color-surface', light: 'oklch(0.965 0.005 80)', dark: 'oklch(0.19 0.01 80)', desc: 'Card surfaces' },
  { name: '--color-accent', light: 'oklch(0.50 0.14 250)', dark: 'oklch(0.68 0.12 250)', desc: 'Links, one interactive' },
  { name: '--color-accent-hover', light: 'oklch(0.42 0.11 250)', dark: 'oklch(0.75 0.12 250)', desc: 'Accent hover' },
  { name: '--color-code-bg', light: 'oklch(0.945 0.005 80)', dark: 'oklch(0.20 0.005 80)', desc: 'Code background' },
];

// Computed WCAG 2.x contrast ratios (OKLCH → sRGB → relative luminance)
const contrastPairs = [
  { pair: 'fg on bg', light: '17.5:1', dark: '14.4:1', grade: 'AAA' },
  { pair: 'fg-muted on bg', light: '7.5:1', dark: '7.3:1', grade: 'AAA' },
  { pair: 'muted on bg', light: '4.7:1', dark: '4.9:1', grade: 'AA' },
  { pair: 'muted on surface', light: '4.6:1', dark: '4.7:1', grade: 'AA' },
  { pair: 'accent on bg', light: '5.6:1', dark: '6.8:1', grade: 'AA' },
  { pair: 'fg on surface', light: '17.0:1', dark: '13.7:1', grade: 'AAA' },
  { pair: 'border-bold on bg', light: '3.4:1', dark: '3.2:1', grade: 'Non-text' },
];

const spacing = [
  { name: '--space-1', value: '0.25rem', px: '4px' },
  { name: '--space-2', value: '0.5rem', px: '8px' },
  { name: '--space-3', value: '0.75rem', px: '12px' },
  { name: '--space-4', value: '1rem', px: '16px' },
  { name: '--space-5', value: '1.5rem', px: '24px' },
  { name: '--space-6', value: '2rem', px: '32px' },
  { name: '--space-7', value: '3rem', px: '48px' },
  { name: '--space-8', value: '4rem', px: '64px' },
  { name: '--space-9', value: '6rem', px: '96px' },
  { name: '--space-10', value: '8rem', px: '128px' },
];
---

<BaseLayout title="Tokens" description="Visual reference for all Remarque design tokens — colors, spacing, content widths, and motion.">
  <div class="pt-[var(--space-9)]">
    <h1 class="text-display font-display text-[var(--color-fg)]">Design Tokens</h1>
    <p class="mt-4 font-mono text-[var(--text-meta)] tracking-[var(--tracking-meta)] text-[var(--color-muted)]">
      The single source of truth for all visual decisions. Defined in tokens.css.
    </p>
  </div>

  <!-- Colors: Dual-Mode Side-by-Side -->
  <section class="mt-12">
    <h2 class="text-section font-display text-[var(--color-fg)] mb-2">Colors</h2>
    <p class="text-[var(--text-body)] text-[var(--color-fg-muted)] mb-6 max-w-reading">
      Every color token has independently tuned light and dark values. Dark mode is not an inversion — it is a separate palette.
    </p>
    <div class="border-t border-[var(--color-border)]">
      {colorPairs.map((c) => (
        <div class="py-4 border-b border-[var(--color-border)] grid grid-cols-[1fr_auto_auto] sm:grid-cols-[1fr_100px_100px] gap-3 items-center">
          <div>
            <p class="font-mono text-[var(--text-meta)] tracking-[var(--tracking-meta)] text-[var(--color-fg)]">{c.name}</p>
            <p class="text-[var(--text-micro)] text-[var(--color-fg-muted)]">{c.desc}</p>
          </div>
          <div class="flex flex-col items-center gap-1">
            <div class="w-16 h-8 rounded-sm border border-[var(--color-border)]" style={`background: ${c.light};`}></div>
            <span class="font-mono text-[var(--text-micro)] text-[var(--color-muted)]">light</span>
          </div>
          <div class="flex flex-col items-center gap-1">
            <div class="w-16 h-8 rounded-sm border border-[var(--color-border-bold)]" style={`background: ${c.dark};`}></div>
            <span class="font-mono text-[var(--text-micro)] text-[var(--color-muted)]">dark</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- WCAG Contrast Ratios -->
  <section class="mt-12">
    <h2 class="text-section font-display text-[var(--color-fg)] mb-2">Contrast Ratios</h2>
    <p class="text-[var(--text-body)] text-[var(--color-fg-muted)] mb-6 max-w-reading">
      Computed WCAG 2.x compliance for key color pairings. Text pairings meet AA or better; --color-border is decorative-only (functional boundaries use --color-border-bold, which meets the 3:1 non-text minimum).
    </p>
    <div class="border-t border-[var(--color-border)]">
      <div class="py-3 border-b border-[var(--color-border)] grid grid-cols-4 gap-4 text-label">
        <span>Pairing</span>
        <span>Light</span>
        <span>Dark</span>
        <span>WCAG</span>
      </div>
      {contrastPairs.map((cp) => (
        <div class="py-3 border-b border-[var(--color-border)] grid grid-cols-4 gap-4 items-center">
          <span class="font-mono text-[var(--text-meta)] text-[var(--color-fg)]">{cp.pair}</span>
          <span class="font-mono text-[var(--text-meta)] text-[var(--color-fg-muted)]">{cp.light}</span>
          <span class="font-mono text-[var(--text-meta)] text-[var(--color-fg-muted)]">{cp.dark}</span>
          <span class="font-mono text-[var(--text-meta)] font-medium text-[var(--color-fg)]">
            {cp.grade}
          </span>
        </div>
      ))}
    </div>
  </section>

  <!-- Spacing Scale -->
  <section class="mt-12">
    <h2 class="text-section font-display text-[var(--color-fg)] mb-2">Spacing Scale</h2>
    <p class="text-[var(--text-body)] text-[var(--color-fg-muted)] mb-6 max-w-reading">Deliberately generous. The upper values provide the breathing room that distinguishes editorial layouts from dashboard UIs.</p>
    <div class="border-t border-[var(--color-border)]">
      {spacing.map((s) => (
        <div class="py-3 border-b border-[var(--color-border)] flex items-center gap-4">
          <div class="font-mono text-[var(--text-meta)] tracking-[var(--tracking-meta)] text-[var(--color-muted)] w-28 shrink-0">{s.name}</div>
          <div class="font-mono text-[var(--text-meta)] text-[var(--color-fg-muted)] w-16 shrink-0">{s.px}</div>
          <div class="flex-1">
            <div class="h-3 rounded-sm bg-[var(--color-accent)]" style={`width: ${s.value}; max-width: 100%;`}></div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Content Widths -->
  <section class="mt-12">
    <h2 class="text-section font-display text-[var(--color-fg)] mb-2">Content Widths</h2>
    <p class="text-[var(--text-body)] text-[var(--color-fg-muted)] mb-6 max-w-reading">The three content widths are the most critical layout tokens. Prose is always constrained to the reading width.</p>
    <div class="space-y-4">
      <div>
        <div class="font-mono text-[var(--text-meta)] tracking-[var(--tracking-meta)] text-[var(--color-muted)] mb-2">--content-reading: 46rem (~740px) — prose, essays, articles</div>
        <div class="h-4 rounded-sm bg-[var(--color-accent)] opacity-40" style="max-width: 46rem;"></div>
      </div>
      <div>
        <div class="font-mono text-[var(--text-meta)] tracking-[var(--tracking-meta)] text-[var(--color-muted)] mb-2">--content-standard: 72rem (~1152px) — project pages, wider layouts</div>
        <div class="h-4 rounded-sm bg-[var(--color-accent)] opacity-60" style="max-width: 72rem;"></div>
      </div>
      <div>
        <div class="font-mono text-[var(--text-meta)] tracking-[var(--tracking-meta)] text-[var(--color-muted)] mb-2">--content-wide: 88rem (~1408px) — outer container, navigation</div>
        <div class="h-4 rounded-sm bg-[var(--color-accent)] opacity-80" style="max-width: 88rem;"></div>
      </div>
    </div>
  </section>

  <!-- Border Radius & Motion -->
  <section class="mt-12 mb-12">
    <h2 class="text-section font-display text-[var(--color-fg)] mb-6">Borders, Radius & Motion</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
      <div>
        <h3 class="font-body text-[var(--text-body)] font-semibold text-[var(--color-fg)] mb-4">Border Radius</h3>
        <div class="flex items-end gap-6">
          <div class="text-center">
            <div class="w-16 h-16 border border-[var(--color-border-bold)] rounded-sm"></div>
            <p class="font-mono text-[var(--text-micro)] text-[var(--color-muted)] mt-2">--radius-sm<br/>0.25rem</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 border border-[var(--color-border-bold)] rounded-[var(--radius-md)]"></div>
            <p class="font-mono text-[var(--text-micro)] text-[var(--color-muted)] mt-2">--radius-md<br/>0.5rem (max)</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 border border-[var(--color-border-bold)]"></div>
            <p class="font-mono text-[var(--text-micro)] text-[var(--color-muted)] mt-2">--radius-none<br/>0</p>
          </div>
        </div>
      </div>
      <div>
        <h3 class="font-body text-[var(--text-body)] font-semibold text-[var(--color-fg)] mb-4">Motion</h3>
        <div class="space-y-3">
          <div class="flex items-center gap-4">
            <span class="font-mono text-[var(--text-meta)] text-[var(--color-muted)] w-32">--motion-fast</span>
            <span class="font-mono text-[var(--text-meta)] text-[var(--color-fg)]">120ms</span>
            <span class="text-[var(--text-meta)] text-[var(--color-fg-muted)]">hover, focus</span>
          </div>
          <div class="flex items-center gap-4">
            <span class="font-mono text-[var(--text-meta)] text-[var(--color-muted)] w-32">--motion-normal</span>
            <span class="font-mono text-[var(--text-meta)] text-[var(--color-fg)]">180ms</span>
            <span class="text-[var(--text-meta)] text-[var(--color-fg-muted)]">theme transitions</span>
          </div>
          <div class="flex items-center gap-4">
            <span class="font-mono text-[var(--text-meta)] text-[var(--color-muted)] w-32">--motion-easing</span>
            <span class="font-mono text-[var(--text-meta)] text-[var(--color-fg)]">ease-out</span>
            <span class="text-[var(--text-meta)] text-[var(--color-fg-muted)]">all transitions</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
