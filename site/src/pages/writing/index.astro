---
/**
 * Writing — archive/landing page, restyled as the Broadsheet pattern's
 * reference demo (issue #36). Exercises three of the pattern's four
 * primitives: masthead, lead article, numbered entry list. The fourth
 * (post-header kicker) lives on an individual post page instead —
 * see `writing/against-decoration.astro` — since that primitive is
 * scoped to a post's own header, not the archive that links to it.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import BroadsheetEntry from '../../components/BroadsheetEntry.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Writing" description="Long-form essays on design, technology, and craft.">
  <header class="remarque-masthead">
    <p class="remarque-masthead-kicker"><span>Field Notes</span></p>
    <h1 class="remarque-masthead-title">Writing on <em>Typography</em></h1>
    <p class="remarque-masthead-dateline">
      <span class="remarque-rule" aria-hidden="true"></span>
      <span>2 essays</span>
      <span class="remarque-rule" aria-hidden="true"></span>
    </p>
  </header>

  <BroadsheetEntry
    variant="lead"
    title="Typography as Interface"
    href={`${base}writing/typography-as-interface`}
    section="Essay"
    readingTime="8 min read"
    date="2026-04-08"
    description="When typography is the primary visual system, every decision about type is a decision about interface. This essay explores what happens when you stop decorating and start reading."
  />

  <hr class="remarque-broadsheet-rule" />

  <ul class="remarque-entry-list">
    <BroadsheetEntry
      variant="entry"
      number={2}
      title="Against Decoration"
      href={`${base}writing/against-decoration`}
      section="Essay"
      readingTime="6 min read"
      date="2026-03-29"
      description="The modern web is drowning in visual noise. Gradients, glassmorphism, animated backgrounds. What if the antidote is restraint?"
    />
  </ul>
</BaseLayout>
