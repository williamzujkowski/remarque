---
/**
 * Landing — Page Archetype
 *
 * The homepage. Sets the tone.
 * Always includes: clear identity statement (serif, large), navigation to content types, generous whitespace.
 * Never includes: hero images, multiple CTAs, feature grids, testimonials, newsletter signups above fold.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Home">
  <div class="pt-remarque-10 pb-remarque-9">
    <h1 class="text-display font-display text-[var(--color-fg)] max-w-[20ch]">
      A typography-first design system for the web.
    </h1>
    <p class="mt-6 text-[var(--text-body-lg)] leading-[var(--leading-body)] text-[var(--color-fg-muted)] max-w-reading">
      Remarque is an opinionated design system built for personal websites, blogs, project pages, and technical writing. It prioritizes reading comfort, typographic hierarchy, and visual consistency over component variety or decorative flourish.
    </p>
    <div class="mt-8 flex gap-4 font-mono text-[var(--text-meta)] tracking-[var(--tracking-meta)]">
      <a href={`${base}start`} class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors duration-[var(--motion-fast)] no-underline">Get Started</a>
      <span class="text-[var(--color-border)]">|</span>
      <a href="https://github.com/williamzujkowski/remarque" class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors duration-[var(--motion-fast)] no-underline">GitHub</a>
      <span class="text-[var(--color-border)]">|</span>
      <a href={`${base}rss.xml`} class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors duration-[var(--motion-fast)] no-underline">RSS</a>
    </div>
  </div>

  <!-- Design System Docs -->
  <div class="border-t border-[var(--color-border)] pt-8 pb-8">
    <p class="text-label mb-6">System</p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      <a href={`${base}specimen`} class="group block no-underline">
        <h2 class="text-section font-display text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition-colors duration-[var(--motion-fast)]">Specimen</h2>
        <p class="mt-2 text-[var(--text-body)] text-[var(--color-fg-muted)]">The three-font system rendered at every scale step.</p>
      </a>
      <a href={`${base}tokens`} class="group block no-underline">
        <h2 class="text-section font-display text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition-colors duration-[var(--motion-fast)]">Tokens</h2>
        <p class="mt-2 text-[var(--text-body)] text-[var(--color-fg-muted)]">Colors, spacing, widths, motion — the visual source of truth.</p>
      </a>
      <a href={`${base}start`} class="group block no-underline">
        <h2 class="text-section font-display text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition-colors duration-[var(--motion-fast)]">Start</h2>
        <p class="mt-2 text-[var(--text-body)] text-[var(--color-fg-muted)]">Install, configure, and copy-paste page archetypes.</p>
      </a>
    </div>
  </div>

  <!-- Content Sections -->
  <div class="border-t border-[var(--color-border)] pt-8 pb-8">
    <p class="text-label mb-6">Content</p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      <a href={`${base}writing`} class="group block no-underline">
        <h2 class="text-section font-display text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition-colors duration-[var(--motion-fast)]">Writing</h2>
        <p class="mt-2 text-[var(--text-body)] text-[var(--color-fg-muted)]">Long-form essays on design, typography, and craft.</p>
      </a>
      <a href={`${base}projects`} class="group block no-underline">
        <h2 class="text-section font-display text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition-colors duration-[var(--motion-fast)]">Projects</h2>
        <p class="mt-2 text-[var(--text-body)] text-[var(--color-fg-muted)]">Technical work, architecture, and open source.</p>
      </a>
      <a href={`${base}notes`} class="group block no-underline">
        <h2 class="text-section font-display text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition-colors duration-[var(--motion-fast)]">Notes</h2>
        <p class="mt-2 text-[var(--text-body)] text-[var(--color-fg-muted)]">Short observations, bookmarks, and references.</p>
      </a>
    </div>
  </div>

  <!-- Recent -->
  <div class="border-t border-[var(--color-border)] pt-8">
    <p class="text-label mb-6">Recent</p>
    <ul class="space-y-4 list-none p-0">
      <li>
        <a href={`${base}writing/typography-as-interface`} class="text-[var(--color-fg)] hover:text-[var(--color-accent)] transition-colors duration-[var(--motion-fast)] no-underline">Typography as Interface</a>
        <span class="font-mono text-[var(--text-meta)] tracking-[var(--tracking-meta)] text-[var(--color-muted)] ml-3">Apr 8, 2026</span>
      </li>
      <li>
        <a href={`${base}projects/remarque`} class="text-[var(--color-fg)] hover:text-[var(--color-accent)] transition-colors duration-[var(--motion-fast)] no-underline">Remarque Design System</a>
        <span class="font-mono text-[var(--text-meta)] tracking-[var(--tracking-meta)] text-[var(--color-muted)] ml-3">Apr 6, 2026</span>
      </li>
      <li>
        <a href={`${base}writing/against-decoration`} class="text-[var(--color-fg)] hover:text-[var(--color-accent)] transition-colors duration-[var(--motion-fast)] no-underline">Against Decoration</a>
        <span class="font-mono text-[var(--text-meta)] tracking-[var(--tracking-meta)] text-[var(--color-muted)] ml-3">Mar 29, 2026</span>
      </li>
    </ul>
  </div>
</BaseLayout>
