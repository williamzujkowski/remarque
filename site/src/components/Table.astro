---
/**
 * Table — reference component for a standalone data table (issue #30).
 * Renders `.remarque-table` / `.remarque-table-wrap` (forms.css) — the
 * same visual language as `.remarque-prose table` (mono `th`, 2px header
 * rule, 1px row rules, tabular-lining numeric columns) WITHOUT requiring
 * the full `.remarque-prose` wrapper, which also applies oldstyle
 * proportional numerals and prose spacing this data grid doesn't want.
 * Demo scaffolding, not package API — the real contract is the CSS
 * classes documented in REMARQUE.md's "Forms" > "Standalone tables".
 */
interface Column {
  key: string;
  label: string;
  /** Right-aligns and applies tabular-lining figures — REMARQUE.md's numerals rule for metadata. */
  num?: boolean;
}

interface Props {
  caption?: string;
  columns: Column[];
  rows: Record<string, string | number>[];
}

const { caption, columns, rows } = Astro.props;
---

<div class="remarque-table-wrap">
  <table class="remarque-table">
    {caption && <caption>{caption}</caption>}
    <thead>
      <tr>
        {columns.map((col) => (
          <th class={col.num ? "num" : undefined}>{col.label}</th>
        ))}
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr>
          {columns.map((col) => (
            <td class={col.num ? "num" : undefined}>{row[col.key]}</td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
</div>
